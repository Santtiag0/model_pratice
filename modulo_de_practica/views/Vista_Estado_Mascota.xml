<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_mascota_form" model="ir.ui.view">
        <field name="name">mi_modulo.mascota.form</field>
        <field name="model">mi_modulo.mascota</field>
        <field name="arch" type="xml">
            <form string="Mascotas">
                <header>
                    <button name="action_registrado" string="Registrar"
                            type="object" class="oe_highlight"
                            invisible="state != 'borrado'"/>
                    
                    <button name="action_adoptado" string="Marcar Adoptado"
                            type="object" class="oe_highlight"
                            invisible="state != 'registrado'"/>
                    
                    <button name="action_borrado" string="Volver a Borrado"
                            type="object"
                            invisible="state == 'borrado'"/>

                    <field name="state" widget="statusbar" 
                           statusbar_visible="borrado,registrado,adoptado"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Nombre de la Mascota"/>
                        <h1>
                            <field name="name" placeholder="Ej. Firulais"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group>
                            <field name="tipo"/>
                            <field name="dueno_id"/>
                            <field name="fecha_de_nacimiento"/>
                        </group>
                        <group>
                            <field name="edad"/>
                            <field name="peso"/>
                            <field name="es_vacunado"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Notas Extra" name="notes">
                            <field name="nota" placeholder="Añade observaciones aquí..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- La vista Tree y Search  -->
    <record id="view_mascota_tree" model="ir.ui.view">
        <field name="name">mi_modulo.mascota.tree</field>
        <field name="model">mi_modulo.mascota</field>
        <field name="arch" type="xml">
            <tree string="Mascotas">
                <field name="name"/>
                <field name="tipo"/>
                <field name="dueno_id"/>
                <field name="edad"/>
                <field name="state" widget="badge" 
                       decoration-info="state == 'borrado'" 
                       decoration-success="state == 'adoptado'"/>
            </tree>
        </field>
    </record>
</odoo>